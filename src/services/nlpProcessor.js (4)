// KEYWORD CHECKS
// ============================================================

const SERVICE_KEYWORDS = {
  videoGeneration: ['video', 'clip', 'slideshow', 'advertisement', 'promo', 'animation'],
  documentAnalysis: ['analyze', 'analysis', 'research', 'document', 'paper', 'academic', 'legal', 'contract', 'financial', 'invoice'],
  iftms: ['freight', 'transport', 'cargo', 'iftms', 'operator', 'vehicle', 'driver', 'truck', 'logistics']
};

function checkServiceSwitch(message) {
  if (!message) return null;
  const lower = message.toLowerCase();
  for (const [serviceId, keywords] of Object.entries(SERVICE_KEYWORDS)) {
    if (keywords.some(kw => lower.includes(kw.toLowerCase()))) {
      return serviceId;
    }
  }
  return null;
}

const YES_WORDS = ['yes', 'yeah', 'yep', 'sure', 'ok', 'okay', 'yup', 'of course'];
const NO_WORDS = ['no', 'nope', 'nah', 'not yet', 'skip'];

function checkYesNo(message) {
  if (!message) return null;
  const lower = message.trim().toLowerCase();
  if (YES_WORDS.some(w => lower === w || lower.startsWith(w + ' '))) return 'yes';
  if (NO_WORDS.some(w => lower === w || lower.startsWith(w + ' '))) return 'no';
  return null;
}

// ============================================================
// MODEL WORKER
// ============================================================

export async function initModel() {
  if (modelWorker) return true;
  return new Promise((resolve) => {
    try {
      modelWorker = new Worker(new URL('./modelWorker.js', import.meta.url), { type: 'module' });
      modelWorker.onmessage = (e) => {
        const { type, data, id } = e.data;
        if (type === 'ready') { workerReady = true; resolve(true); }
        if (type === 'response' && callbacks.has(id)) {
          callbacks.get(id)(data);
          callbacks.delete(id);
        }
        if (type === 'error') { console.error('Worker error:', e.data.error); if (!workerReady) resolve(true); }
      };
      modelWorker.onerror = () => resolve(true);
      setTimeout(() => resolve(true), 5000);
    } catch (error) {
      resolve(true);
    }
  });
}

function callModel(data) {
  return new Promise((resolve) => {
    const id = callbackId++;
    callbacks.set(id, resolve);
    if (modelWorker && workerReady) {
      modelWorker.postMessage({ type: 'predict', data, id });
    } else {
      const msg = data.userMessage?.toLowerCase() || '';
      let action = 'save';
      let value = msg;
      
      if (msg.includes('help') || msg.includes('what can you do')) {
        action = 'help';
      } else if (msg.includes('status') || msg.includes('progress')) {
        action = 'status';
      } else if (msg.includes('complete') || msg.includes('done') || msg.includes('finish')) {
        action = 'complete';
      }
      
      resolve({ action, value });
    }
    setTimeout(() => {
      if (callbacks.has(id)) {
        callbacks.delete(id);
        resolve({ action: 'fallback' });
      }
    }, 15000);
  });
}

// ============================================================
// VALIDATION
// ============================================================

function validateField(input, field) {
  const value = input?.toString().trim();
  if (!value) return { valid: false, message: field.error || 'Cannot be empty' };

  if (field.validation === 'choice' && field.options) {
    const match = field.options.find(opt => opt.toLowerCase() === value.toLowerCase());
    if (match) return { valid: true, value: match };
    return { valid: false, message: `Choose from: ${field.options.join(', ')}` };
  }

  if (field.regex && !field.regex.test(value)) {
    return { valid: false, message: field.error || `Invalid. Example: ${field.example}` };
  }

  return { valid: true, value };
}

function saveToState(fieldName, value) {
  const state = getState();
  const step = getStep();
  if (!step) return;
  if (step.type === 'form') {
    if (!state.collectedData.operator) state.collectedData.operator = {};
    state.collectedData.operator[fieldName] = value;
  } else if (step.subprocess) {
    state.currentItem[fieldName] = value;
  }
  saveGlobalState();
}

// ============================================================
// VIN
// ============================================================

function processVIN(input) {
  try {
    if (!input || !vinDecoder.isVIN(input)) return null;
    const vin = vinDecoder.extractVIN(input) || input.trim().toUpperCase();
    return vinDecoder.getCompleteVehicleData(vin);
  } catch (error) {
    return null;
  }
}

function isAutoFillField(field) {
  return field && field.autoFill === true;
}

// ============================================================
// STEP INTRO & COMPLETE
// ============================================================

function stepIntro() {
  const step = getStep();
  const state = getState();
  if (!step) return { text: 'How can I help?', html: '<div>How can I help?</div>', isStructured: true };

  if (step.isFinal || step.type === 'summary' || step.type === 'result') {
    return buildComplete();
  }

  if (step.type === 'file_upload') {
    return { text: step.prompt, html: `<div>${step.prompt}</div>`, isStructured: true };
  }

  if (step.subprocess && step.subprocess.fields) {
    const fields = step.subprocess.fields;
    let firstNonAutoFillIndex = -1;
    for (let i = 0; i < fields.length; i++) {
      if (!isAutoFillField(fields[i])) {
        firstNonAutoFillIndex = i;
        break;
      }
    }
    if (firstNonAutoFillIndex === -1) {
      state.waitingForAdd = true;
      state.currentFieldIndex = 0;
      saveGlobalState();
      return {
        text: step.subprocess.addPrompt,
        html: `<div><strong>${step.title}</strong><br>${step.subprocess.addPrompt}</div>`,
        isStructured: true
      };
    }
    state.waitingForAdd = true;
    state.currentFieldIndex = firstNonAutoFillIndex;
    saveGlobalState();
    const firstField = fields[firstNonAutoFillIndex];
    return {
      text: firstField.question,
      html: `<div><strong>${step.title}</strong><br>${firstField.question}</div>`,
      isStructured: true
    };
  }

  const firstField = step.fields?.[0];
  if (firstField) {
    return {
      text: firstField.question,
      html: `<div><strong>${step.title}</strong><br>${firstField.question}</div>`,
      isStructured: true
    };
  }

  return { text: step.prompt || 'How can I help?', html: `<div>${step.prompt || 'How can I help?'}</div>`, isStructured: true };
}

function buildComplete() {
  const state = getState();
  const svc = getService();
  let summary = `${svc.name} Complete!\n\n`;
  for (const [key, val] of Object.entries(state.collectedData)) {
    if (!val) continue;
    summary += `📋 ${key.toUpperCase()}:\n`;
    if (Array.isArray(val)) {
      val.forEach((item, i) => {
        summary += `  ${i + 1}. ${Object.entries(item).map(([k, v]) => `${k}: ${v}`).join(', ')}\n`;
      });
    } else if (typeof val === 'object') {
      Object.entries(val).forEach(([k, v]) => { summary += `  • ${k}: ${v}\n`; });
    }
  }
  return {
    text: summary,
    html: `<div><pre style="white-space:pre-wrap">${summary}</pre></div>`,
    isStructured: true,
    isComplete: true
  };
}

// ============================================================
// ACTION EXECUTOR
// ============================================================

function executeAction(action, rawValue, originalMessage) {
  const state = getState();
  const step = getStep();
  const currentField = getCurrentField();

  if (!step) {
    return { text: 'System error', html: '<div>System error</div>', isStructured: true };
  }

  if (!originalMessage || originalMessage.trim() === '') {
    if (currentField) {
      return { text: currentField.question, html: `<div>${currentField.question}</div>`, isStructured: true };
    }
    return { text: 'Please enter a value.', html: '<div>Please enter a value.</div>', isStructured: true };
  }

  switch (action) {
    case 'save': {
      if (!currentField) {
        return { text: `I received: ${originalMessage}`, html: `<div>I received: ${originalMessage}</div>`, isStructured: true };
      }

      // VIN handling
      if (currentField.name === 'vinNumber' || currentField.name === 'chassisNumber') {
        const vinResult = processVIN(originalMessage);
        if (vinResult) {
          const fields = step.subprocess?.fields || [];
          saveToState('vinNumber', vinResult.vinNumber);
          state.currentFieldIndex++;
          for (const field of fields) {
            if (isAutoFillField(field) && vinResult[field.name] && vinResult[field.name] !== 'Unknown' && vinResult[field.name] !== '') {
              saveToState(field.name, vinResult[field.name]);
              state.currentFieldIndex++;
            }
          }
          while (state.currentFieldIndex < fields.length && isAutoFillField(fields[state.currentFieldIndex])) {
            state.currentFieldIndex++;
          }
          saveGlobalState();
          if (state.currentFieldIndex >= fields.length) {
            if (step.subprocess) {
              const key = step.subprocess.onValid.collectionKey;
              state.collectedData[key].push({ ...state.currentItem });
              state.currentItem = {};
              state.currentFieldIndex = 0;
              state.waitingForAdd = true;
              saveGlobalState();
              return {
                text: step.subprocess.addPrompt,
                html: `<div>✅ Vehicle saved!<br>${step.subprocess.addPrompt}</div>`,
                isStructured: true
              };
            }
          }
          const nextField = getCurrentField();
          return {
            text: nextField?.question || 'Next:',
            html: `<div>${nextField?.question || ''}</div>`,
            isStructured: true
          };
        }
      }

      // Normal save
      const valueToTry = rawValue || originalMessage;
      const validation = validateField(valueToTry, currentField);
      if (!validation.valid) {
        return {
          text: validation.message,
          html: `<div class="error">❌ ${validation.message}<br>${currentField.question}</div>`,
          isStructured: true
        };
      }
      saveToState(currentField.name, validation.value);
      state.currentFieldIndex++;

      const fields = step.subprocess?.fields || step.fields || [];
      while (state.currentFieldIndex < fields.length && isAutoFillField(fields[state.currentFieldIndex])) {
        state.currentFieldIndex++;
      }

      if (state.currentFieldIndex >= fields.length) {
        if (step.subprocess) {
          if (Object.keys(state.currentItem).length > 0) {
            const key = step.subprocess.onValid.collectionKey;
            state.collectedData[key].push({ ...state.currentItem });
            state.currentItem = {};
          }
          state.currentFieldIndex = 0;
          state.waitingForAdd = true;
          saveGlobalState();
          return {
            text: step.subprocess.addPrompt,
            html: `<div>✅ ${step.subprocess.itemName} saved!<br>${step.subprocess.addPrompt}</div>`,
            isStructured: true
          };
        } else {
          state.currentStep = step.onValid?.nextStep || state.currentStep + 1;
          state.currentFieldIndex = 0;
          saveGlobalState();
          return stepIntro();
        }
      }

      saveGlobalState();
      const nextField = getCurrentField();
      return {
        text: nextField?.question || 'Next:',
        html: `<div>✅ Saved!<br>${nextField?.question || ''}</div>`,
        isStructured: true
      };
    }

    case 'yes': {
      if (state.waitingForAdd) {
        state.waitingForAdd = false;
        state.currentItem = {};
        state.currentFieldIndex = 0;
        saveGlobalState();
        const firstField = step.subprocess.fields[0];
        return { text: firstField.question, html: `<div>${firstField.question}</div>`, isStructured: true };
      }
      if (state.waitingForContinue) {
        state.waitingForContinue = false;
        state.currentStep = step.subprocess.onValid.nextStep;
        state.currentFieldIndex = 0;
        saveGlobalState();
        return stepIntro();
      }
      break;
    }

    case 'no': {
      if (state.waitingForAdd) {
        state.waitingForAdd = false;
        state.waitingForContinue = true;
        saveGlobalState();
        return {
          text: step.subprocess.continuePrompt,
          html: `<div>${step.subprocess.continuePrompt}</div>`,
          isStructured: true
        };
      }
      if (state.waitingForContinue) {
        state.waitingForContinue = false;
        state.currentStep = step.subprocess.onValid.nextStep;
        state.currentFieldIndex = 0;
        saveGlobalState();
        return stepIntro();
      }
      break;
    }

    case 'switch_service': {
      const target = rawValue;
      if (target && services[target]) {
        currentService = target;
        if (!serviceStates[target]) {
          serviceStates[target] = {
            currentStep: services[target].initStep || 1,
            currentFieldIndex: 0,
            waitingForAdd: false,
            waitingForContinue: false,
            currentItem: {},
            collectedData: JSON.parse(JSON.stringify(services[target].collectedData || {}))
          };
        }
        saveGlobalState();
        return {
          text: `Switched to ${services[target].name}`,
          html: `<div>🔄 Switched to <strong>${services[target].name}</strong><br>${services[target].description}</div>`,
          isStructured: true
        };
      }
      break;
    }

    case 'help': {
      const list = Object.values(services).map(s => `• ${s.name}: ${s.description}`).join('\n');
      return {
        text: `Available services:\n${list}`,
        html: `<div>📚 Available services:<br>${list.replace(/\n/g, '<br>')}</div>`,
        isStructured: true
      };
    }

    case 'status': {
      const collected = Object.entries(state.collectedData)
        .filter(([, v]) => v && (Array.isArray(v) ? v.length > 0 : Object.keys(v).length > 0))
        .map(([k, v]) => `${k}: ${Array.isArray(v) ? v.length + ' item(s)' : '✓'}`)
        .join(', ') || 'nothing yet';
      const svc = getService();
      return {
        text: `Service: ${svc?.name || 'Unknown'} | Step: ${state.currentStep} | Collected: ${collected}`,
        html: `<div>📊 <strong>${svc?.name || 'Unknown'}</strong><br>Step: ${state.currentStep}<br>Collected: ${collected}</div>`,
        isStructured: true
      };
    }

    case 'complete': {
      return buildComplete();
    }

    default: {
      return { text: `I understood: ${originalMessage}`, html: `<div>I understood: ${originalMessage}</div>`, isStructured: true };
    }
  }

  if (currentField) {
    return { text: currentField.question, html: `<div>${currentField.question}</div>`, isStructured: true };
  }
  return { text: getStep()?.prompt || 'How can I help?', html: `<div>${getStep()?.prompt || 'How can I help?'}</div>`, isStructured: true };
}

// ============================================================
// CORE PROCESS MESSAGE
// ============================================================

export async function processMessage(message, file) {
  try {
    console.log('📨 Processing:', message || '[file]');

    // Initialize services (will populate DB if empty)
    await initializeServices();
    
    await initModel();
    loadGlobalState();

    // File upload
    if (file) {
      const step = getStep();
      if (step?.type === 'file_upload') {
        const state = getState();
        state.collectedData.document = { name: file.name, size: file.size };
        state.currentStep = step.onValid.nextStep;
        state.currentFieldIndex = 0;
        saveGlobalState();
        return {
          text: `File "${file.name}" received. ${getStep()?.prompt || 'What next?'}`,
          html: `<div>📄 File received: <strong>${file.name}</strong><br>${getStep()?.prompt || ''}</div>`,
          isStructured: true
        };
      }
      return { text: 'File received', html: '<div>📎 File received</div>', isStructured: false };
    }

    if (!message) return stepIntro();

    // Service switch detection
    const switchTarget = checkServiceSwitch(message);
    if (switchTarget && switchTarget !== currentService && services[switchTarget]) {
      currentService = switchTarget;
      if (!serviceStates[switchTarget]) {
        serviceStates[switchTarget] = {
          currentStep: services[switchTarget].initStep || 1,
          currentFieldIndex: 0,
          waitingForAdd: false,
          waitingForContinue: false,
          currentItem: {},
          collectedData: JSON.parse(JSON.stringify(services[switchTarget].collectedData || {}))
        };
      }
      saveGlobalState();
      return {
        text: `Switched to ${services[switchTarget].name}`,
        html: `<div>🔄 Switched to <strong>${services[switchTarget].name}</strong><br>${services[switchTarget].description}</div>`,
        isStructured: true
      };
    }

    // Yes/No handling
    const state = getState();
    if (state.waitingForAdd || state.waitingForContinue) {
      const yesno = checkYesNo(message);
      if (yesno) {
        return executeAction(yesno, null, message);
      }
    }

    // VIN handling
    if (message && vinDecoder && vinDecoder.isVIN && vinDecoder.isVIN(message)) {
      const vinResult = processVIN(message);
      if (vinResult) {
        const step = getStep();
        if (step && step.subprocess) {
          const currentField = getCurrentField();
          if (currentField && (currentField.name === 'vinNumber' || currentField.name === 'chassisNumber')) {
            return executeAction('save', message, message);
          }
        }
      }
    }

    // Check commands
    const msgLower = message.toLowerCase();
    if (msgLower.includes('help') || msgLower.includes('what can you do')) {
      return executeAction('help', null, message);
    }
    if (msgLower.includes('status') || msgLower.includes('progress')) {
      return executeAction('status', null, message);
    }
    if (msgLower.includes('complete') || msgLower.includes('done') || msgLower.includes('finish')) {
      return executeAction('complete', null, message);
    }

    // Try AI model
    const prediction = await callModel({
      serviceConfig: getService(),
      currentState: getState(),
      userMessage: message
    });

    console.log('🤖 Prediction:', prediction);

    if (prediction && prediction.action) {
      return executeAction(prediction.action, prediction.value, message);
    }

    // Fallback - if we have a current field, try to save
    const currentField = getCurrentField();
    if (currentField) {
      const validation = validateField(message, currentField);
      if (validation.valid) {
        return executeAction('save', validation.value, message);
      }
      return {
        text: validation.message,
        html: `<div class="error">❌ ${validation.message}<br>${currentField.question}</div>`,
        isStructured: true
      };
    }

    return { 
      text: `I received: "${message}"\n\nAvailable services:\n${Object.values(services).map(s => `• ${s.name}`).join('\n')}`,
      html: `<div>I received: "${message}"<br><br>📚 Available services:<br>${Object.values(services).map(s => `• ${s.name}`).join('<br>')}</div>`,
      isStructured: true 
    };

  } catch (error) {
    console.error('❌ Error:', error);
    return {
      text: `Error: ${error.message || 'Unknown error'}`,
      html: `<div class="error">❌ Error: ${error.message || 'Unknown error'}</div>`,
      isStructured: true
    };
  }
}


// ============================================================
// PHONE NUMBER FORMATTING
// ============================================================

function formatPhoneNumber(phone) {
  if (!phone) return phone;
  let cleaned = phone.replace(/[\s\-\(\)]/g, '');
  if (cleaned.startsWith('+251')) return cleaned;
  if (cleaned.startsWith('0')) return '+251' + cleaned.substring(1);
  if (/^[79][0-9]{8}$/.test(cleaned)) return '+251' + cleaned;
  return cleaned;
}

// ============================================================
// STEEL CLIENT WITH RETRY
// ============================================================

class SteelClient {
  constructor(apiKey) {
    this.apiKey = apiKey;
    this.baseUrl = 'https://api.steel.dev/v1';
    this.sessionId = null;
    this.websocketUrl = null;
    this.retryCount = 0;
  }

  async createSession(options = {}) {
    if (!this.apiKey) {
      throw new Error('Steel API key is required. Set VITE_STEEL_API_KEY in .env');
    }

    console.log('🔧 Creating Steel session...');
    
    try {
      const response = await fetch(`${this.baseUrl}/sessions`, {
        method: 'POST',
        headers: {
          'Authorization': `Bearer ${this.apiKey}`,
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          timeout: CONFIG.SESSION_TIMEOUT,
          blockAds: true,
          useProxy: false,
          ...options
        })
      });

      if (!response.ok) {
        const error = await response.text();
        console.error('❌ Session creation failed:', response.status, error);
        
        if (response.status === 401 || response.status === 403) {
          throw new Error('Invalid Steel API key. Please check your VITE_STEEL_API_KEY.');
        } else if (response.status === 429) {
          throw new Error('Rate limit exceeded. Please wait and try again.');
        } else if (response.status === 402) {
          throw new Error('Insufficient credits. Please upgrade your Steel account.');
        } else {
          throw new Error(`Steel API error: ${error}`);
        }
      }

      const data = await response.json();
      this.sessionId = data.id;
      this.websocketUrl = data.websocketUrl;
      this.retryCount = 0;
      console.log(`✅ Session created: ${this.sessionId}`);
      return data;
    } catch (error) {
      console.error('❌ Session creation error:', error.message);
      throw error;
    }
  }

  async runPuppeteerScript(script) {
    if (!this.sessionId) {
      throw new Error('No active Steel session');
    }

    console.log('🔧 Running Puppeteer script...');
    
    try {
      const response = await fetch(`${this.baseUrl}/sessions/${this.sessionId}/puppeteer`, {
        method: 'POST',
        headers: {
          'Authorization': `Bearer ${this.apiKey}`,
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ script })
      });

      if (!response.ok) {
        const error = await response.text();
        console.error('❌ Puppeteer script failed:', response.status, error);
        
        // Check if session is offline - can retry
        if (error.includes('Offline') || error.includes('offline') || response.status === 404) {
          throw new Error('Session offline');
        }
        
        throw new Error(`Failed to run Puppeteer script: ${error}`);
      }

      const result = await response.json();
      this.retryCount = 0;
      console.log('✅ Puppeteer script completed');
      return result;
    } catch (error) {
      console.error('❌ Puppeteer error:', error.message);
      throw error;
    }
  }

  async releaseSession() {
    if (!this.sessionId) return;
    try {
      await fetch(`${this.baseUrl}/sessions/${this.sessionId}`, {
        method: 'DELETE',
        headers: { 'Authorization': `Bearer ${this.apiKey}` }
      });
      console.log(`✅ Session ${this.sessionId} released`);
    } catch (e) {
      console.warn('Failed to release Steel session:', e);
    }
    this.sessionId = null;
    this.websocketUrl = null;
  }
}

// ============================================================
// STEEL LOGIN SCRIPT
// ============================================================

function buildLoginScript(username, password, websocketUrl) {
  return `
    (async () => {
      const puppeteer = require('puppeteer-core');

      console.log('[*] Connecting to browser...');
      const browser = await puppeteer.connect({
        browserWSEndpoint: '${websocketUrl}',
        timeout: 30000
      });

      try {
        console.log('[*] Opening new page...');
        const page = await browser.newPage();

        console.log('[*] Setting user agent...');
        await page.setUserAgent(
          'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36'
        );

        console.log('[*] Navigating to login page: ${CONFIG.LOGIN_URL}');
        await page.goto('${CONFIG.LOGIN_URL}', {
          waitUntil: 'networkidle2',
          timeout: 30000
        });

        console.log('[*] Waiting for login form...');
        await page.waitForSelector('input[name="phone_number"]', {
          timeout: 15000
        });

        console.log('[*] Entering username: ${username}');
        await page.type('input[name="phone_number"]', '${username}');

        console.log('[*] Entering password...');
        await page.type('input[type="password"]', '${password}');

        console.log('[*] Clicking login button...');
        await page.click('button[type="submit"]');

        console.log('[*] Waiting for redirect...');
        let attempts = 0;
        let currentUrl = page.url();
        while (attempts < 30 && !currentUrl.includes('/dashboard')) {
          await page.waitForTimeout(500);
          currentUrl = page.url();
          attempts++;
        }

        const success = currentUrl.includes('/dashboard');
        console.log('[*] Login ' + (success ? 'successful!' : 'failed'));

        const cookies = await page.cookies();
        const screenshot = await page.screenshot({ encoding: 'base64' });
        const title = await page.title();

        await browser.close();

        return {
          success: success,
          url: currentUrl,
          title: title,
          cookies: cookies,
          screenshot: screenshot
        };

      } catch (error) {
        console.error('[*] Error:', error.message);
        await browser.close();
        return {
          success: false,
          error: error.message,
          url: page?.url() || 'unknown'
        };
      }
    })();
  `;
}

// ============================================================
// IFMTS API CLASS WITH RETRY LOGIC
// ============================================================

class IFMTSAPI {
  constructor() {
    this.token = null;
    this.userId = null;
    this.licenseApplicationId = null;
    this.userData = null;
    this.licenseData = null;
    this._isAuthenticated = false;
    this.steelSession = null;
    this.cookies = null;
    this.steelClient = null;
    console.log('🏗️ IFMTSAPI instance created');
  }

  isAuthenticated() {
    return this._isAuthenticated && this.token !== null;
  }

  // ============================================================
  // 1. LOGIN USING STEEL WITH RETRY
  // ============================================================
  
  async login(username, password) {
    const formattedUsername = formatPhoneNumber(username);
    
    console.log('🔐 ===== STEEL LOGIN START =====');
    console.log(`📱 Username: ${formattedUsername}`);
    
    if (!CONFIG.STEEL_API_KEY) {
      console.error('❌ Steel API key missing');
      return { success: false, error: 'Steel API key required. Set VITE_STEEL_API_KEY in .env' };
    }

    let retryCount = 0;
    const maxRetries = CONFIG.MAX_RETRIES;

    while (retryCount < maxRetries) {
      try {
        console.log(`🔄 Attempt ${retryCount + 1}/${maxRetries}...`);
        
        this.steelClient = new SteelClient(CONFIG.STEEL_API_KEY);
        
        // Create Steel session
        const session = await this.steelClient.createSession();
        console.log(`✅ Session created: ${session.id}`);

        // Build login script
        const script = buildLoginScript(formattedUsername, password, this.steelClient.websocketUrl);
        
        // Run the script
        const result = await this.steelClient.runPuppeteerScript(script);
        
        const data = result.result || result;
        
        if (data.success) {
          console.log('✅ Steel login successful!');
          this.cookies = data.cookies;
          this._isAuthenticated = true;
          
          // Try to get token from cookies
          if (this.cookies) {
            const tokenCookie = this.cookies.find(c => 
              c.name === 'access_token' || c.name === 'token' || c.name === 'jwt'
            );
            if (tokenCookie) {
              this.token = tokenCookie.value;
              console.log('✅ Token found in cookies');
            }
          }
          
          // Get user info from API
          console.log('🔍 Fetching user info...');
          await this.getUserInfo();
          
          console.log('✅ ===== LOGIN SUCCESSFUL =====');
          console.log(`👤 User ID: ${this.userId}`);
          console.log(`📋 License App ID: ${this.licenseApplicationId}`);
          
          return { success: true, data };
        } else {
          console.error('❌ Steel login failed:', data.error);
          await this.steelClient.releaseSession();
          
          // If it's an offline error, retry
          if (data.error && (data.error.includes('Offline') || data.error.includes('offline'))) {
            retryCount++;
            if (retryCount < maxRetries) {
              console.log(`⏳ Waiting ${CONFIG.RETRY_DELAY}ms before retry...`);
              await new Promise(resolve => setTimeout(resolve, CONFIG.RETRY_DELAY));
              continue;
            }
          }
          
          return { success: false, error: data.error || 'Login failed' };
        }
      } catch (error) {
        console.error(`❌ Steel login error (attempt ${retryCount + 1}):`, error.message);
        
        if (this.steelClient) {
          await this.steelClient.releaseSession();
        }
        
        // Retry on offline errors
        if (error.message.includes('offline') || error.message.includes('Offline')) {
          retryCount++;
          if (retryCount < maxRetries) {
            console.log(`⏳ Waiting ${CONFIG.RETRY_DELAY}ms before retry...`);
            await new Promise(resolve => setTimeout(resolve, CONFIG.RETRY_DELAY));
            continue;
          }
        }
        
        return { success: false, error: error.message };
      }
    }

    return { success: false, error: `Failed after ${maxRetries} attempts` };
  }

  // ============================================================
  // 2. GET USER INFO
  // ============================================================
  
  async getUserInfo() {
    console.log('👤 ===== GET USER INFO =====');
    console.log(`🌐 API URL: ${CONFIG.API_BASE}/auth/me`);
    
    try {
      const headers = {
        'Accept': 'application/json, text/plain, */*',
      };
      
      if (this.token) {
        headers['Authorization'] = `Bearer ${this.token}`;
      } else if (this.cookies) {
        const cookieString = this.cookies.map(c => `${c.name}=${c.value}`).join('; ');
        headers['Cookie'] = cookieString;
      }

      const response = await fetch(`${CONFIG.API_BASE}/auth/me`, {
        method: 'GET',
        headers: headers,
        credentials: 'include',
      });

      console.log(`📥 Response status: ${response.status}`);

      if (response.status === 401 || response.status === 403) {
        console.warn('⚠️ Unauthorized - session expired');
        this._isAuthenticated = false;
        return null;
      }

      if (!response.ok) {
        console.error('❌ Failed to get user info:', response.status);
        return null;
      }

      const data = await response.json();
      console.log('📥 User info received');
      
      this.userData = data;
      this.userId = data.id;
      
      if (data.licenseApplication) {
        this.licenseData = data.licenseApplication;
        this.licenseApplicationId = data.licenseApplication.id;
        console.log(`✅ License App ID: ${this.licenseApplicationId}`);
        console.log(`✅ Operator: ${data.licenseApplication.operator_name}`);
      }
      
      return data;
    } catch (error) {
      console.error('❌ Failed to get user info:', error.message);
      return null;
    }
  }

